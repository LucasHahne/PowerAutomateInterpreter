# Optional: GitHub repo URL for "Report an issue" / "Suggest a feature" links.
# If not set, the app uses a placeholder; set this to your repo for production.
# VITE_GITHUB_REPO=https://github.com/yourusername/PowerAutomateInterpreter

# Canonical public URL of the deployed site (trailing slash optional). Used for meta tags,
# Open Graph / Twitter cards, sitemap.xml, and robots.txt. GitHub Actions sets this
# automatically for Pages builds. For local `vite build` previews, set explicitly, e.g.:
# VITE_SITE_URL=https://yourusername.github.io/PowerAutomateInterpreter/

# Base path Vite serves from (must match hosting). Root: "/". GitHub project Pages: "/repo-name/"
# VITE_BASE_PATH=/
